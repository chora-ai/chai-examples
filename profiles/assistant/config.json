{
  "channels": {
    "telegram": {
      "botToken": "<TELEGRAM_BOT_TOKEN>"
    }
  },
  "providers": [
    {
      "id": "nearai",
      "endpointType": "openai-compat",
      "baseUrl": "https://cloud-api.near.ai/v1",
      "apiKey": "<NEAR_API_KEY>"
    }
  ],
  "agents": [
    {
      "id": "assistant",
      "role": "orchestrator",
      "defaultProvider": "nearai",
      "defaultModel": "zai-org/GLM-5.1-FP8",
      "enabledSkills": ["notes", "git"],
      "enabledWorkers": ["worker-1", "worker-2"]
    },
    {
      "id": "reviewer",
      "role": "orchestrator",
      "defaultProvider": "nearai",
      "defaultModel": "zai-org/GLM-5.1-FP8",
      "enabledSkills": ["notes", "git-read"]
    },
    {
      "id": "worker-1",
      "role": "worker",
      "defaultProvider": "nearai",
      "defaultModel": "zai-org/GLM-5.1-FP8",
      "enabledSkills": ["notes-read"]
    },
    {
      "id": "worker-2",
      "role": "worker",
      "defaultProvider": "nearai",
      "defaultModel": "zai-org/GLM-5.1-FP8",
      "enabledSkills": ["rss"]
    }
  ]
}
