{
  "providers": [
    {
      "id": "nearai",
      "endpointType": "openai-compat",
      "baseUrl": "https://cloud-api.near.ai/v1",
      "apiKey": "<NEAR_API_KEY>"
    }
  ],
  "agents": [
    {
      "id": "skillsmith",
      "role": "orchestrator",
      "defaultProvider": "nearai",
      "defaultModel": "zai-org/GLM-5.1-FP8",
      "enabledSkills": ["skills", "skills-design"]
    },
    {
      "id": "worker-1",
      "role": "worker",
      "defaultProvider": "nearai",
      "defaultModel": "zai-org/GLM-5.1-FP8",
      "enabledSkills": ["skills-read", "skills-design"]
    }
  ],
  "skills": {
    "lockMode": "warn"
  }
}
