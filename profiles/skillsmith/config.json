{
  "providers": [
    {
      "id": "nearai",
      "endpoint": "openai-compat",
      "baseUrl": "https://cloud-api.near.ai/v1",
      "apiKey": "<API_KEY>"
    }
  ],
  "agents": [
    {
      "id": "orchestrator",
      "role": "orchestrator",
      "defaultProvider": "nearai",
      "defaultModel": "zai-org/GLM-5.1-FP8",
      "enabledProviders": ["nearai"],
      "skillsEnabled": ["files", "skills"]
    }
  ]
}
