{

  "allowlist": {
    "notesmd-cli": ["print", "print-default", "create"]
  },
  "execution": [
    {
      "tool": "notesmd_daily_read",
      "binary": "notesmd-cli",
      "subcommand": "print",
      "args": [
        {
          "param": "path",
          "kind": "positional",
          "resolveCommand": {
            "script": "resolve-daily-path",
            "args": ["$param"]
          }
        }
      ]
    },
    {
      "tool": "notesmd_daily_update",
      "binary": "notesmd-cli",
      "subcommand": "create",
      "args": [
        {
          "param": "date",
          "kind": "positional",
          "resolveCommand": {
            "script": "resolve-daily-path",
            "args": ["$param"]
          }
        },
        {
          "param": "content",
          "kind": "flag",
          "flag": "content"
        },
        {
          "param": "replace",
          "kind": "flagifboolean",
          "flagIfTrue": "--overwrite",
          "flagIfFalse": "--append"
        }
      ]
    }
  ],
  "tools": [
    {
      "name": "notesmd_daily_read",
      "description": "read a daily note",
      "parameters": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "today's date in YYYY-MM-DD format"
          }
        }
      }
    },
    {
      "name": "notesmd_daily_update",
      "description": "create or update a daily note",
      "parameters": {
        "type": "object",
        "required": ["date", "content"],
        "properties": {
          "date": {
            "type": "string",
            "description": "today's date in YYYY-MM-DD format"
          },
          "content": {
            "type": "string",
            "description": "the new or updated content in markdown format"
          },
          "replace": {
            "type": "boolean",
            "description": "true when updating content; false when adding content"
          }
        }
      }
    }
  ]
}
