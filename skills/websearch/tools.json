{
  "tools": [
    {
      "name": "websearch_search",
      "description": "Search the web for a query and return results as structured text with title, url, and content snippet for each result.",
      "parameters": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query string"
          }
        }
      }
    },
    {
      "name": "websearch_fetch",
      "description": "Fetch the readable content of a web page at a given URL.",
      "parameters": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "description": "Full URL to fetch (e.g. 'https://example.com/page')"
          }
        }
      }
    }
  ],
  "allowlist": {
    "curl": ["-sf --max-time 10", "-sf --max-time 15"]
  },
  "execution": [
    {
      "tool": "websearch_search",
      "binary": "curl",
      "subcommand": "-sf --max-time 10",
      "args": [
        {
          "param": "query",
          "kind": "positional",
          "resolveCommand": {
            "script": "build-search-url",
            "args": ["$param"]
          }
        }
      ],
      "postProcess": {
        "script": "format-search-results"
      },
      "maxOutputLines": 200
    },
    {
      "tool": "websearch_fetch",
      "binary": "curl",
      "subcommand": "-sf --max-time 15",
      "args": [
        { "param": "url", "kind": "positional" }
      ],
      "postProcess": {
        "script": "strip-html"
      },
      "maxOutputLines": 500
    }
  ]
}
